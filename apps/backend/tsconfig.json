{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    "outDir": "dist",
    "rootDir": "src",

    "types": ["node", "express"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "noUncheckedIndexedAccess": true
  },
  "references": [{ "path": "../../packages/shared" }],
  "include": ["src/**/*.ts"]
}