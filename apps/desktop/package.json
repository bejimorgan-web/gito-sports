{
  "name": "@gito/desktop",
  "version": "0.1.0",
  "description": "GiTO Live Sports desktop Electron app",
  "author": "GiTO Live Sports Team",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:electron": "tsc -p tsconfig.json && node ./scripts/align-electron-output.js",
    "build": "vite build && npm run build:electron",
    "electron:serve": "node ./scripts/electron-serve.cjs",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron:serve\"",
    "electron:build": "npm run build && electron-builder",
    "start": "npm run build && npx electron ."
  },
  "dependencies": {
    "@gito/shared": "0.1.0",
    "@sentry/electron": "^7.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "hls.js": "^1.6.16",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.6"
  },
  "copyright": "Copyright \u00c2\u00a9 2026 GiTO Live Sports",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.7.0",
    "electron": "29.1.6",
    "wait-on": "^7.0.1",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "com.gito.live-sports",
    "productName": "GiTO Live Sports",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "gito-icon.ico"
    },
    "nsis": {
      "installerIcon": "gito-icon.ico",
      "uninstallerIcon": "gito-icon.ico",
      "installerHeaderIcon": "gito-icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
