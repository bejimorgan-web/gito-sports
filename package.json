{
  "name": "gito-live-sports",
  "version": "0.1.0",
  "private": true,
  "description": "Professional live sports streaming and sports management platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w apps/backend",
    "start": "npm run start -w apps/backend",
    "typecheck": "npm run typecheck -ws",
    "lint": "npm run lint -ws"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "typescript": "^5.4.5"
  }
}