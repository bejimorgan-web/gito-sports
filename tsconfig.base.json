{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "ESNext",
    "moduleResolution": "Node",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@gito/shared": ["packages/shared/src/index.ts"],
      "@gito/shared/*": ["packages/shared/src/*"]
    }
  }
}