{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
  "composite": true,
    "outDir": "dist",
    "rootDir": "src",

    "skipLibCheck": true,
    "esModuleInterop": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
  },
  "include": ["src/**/*.ts"]
}