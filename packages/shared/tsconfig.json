{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
  "composite": true,
    "outDir": "dist",
    "rootDir": "src",

    "skipLibCheck": true,
    "esModuleInterop": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "baseUrl": ".",
    "paths": {
      "@gito/shared": ["src/index.ts"],
      "@gito/shared/*": ["src/*"]
    }
    ,
    "ignoreDeprecations": 6.0
  },
  "include": ["src/**/*.ts"]
}